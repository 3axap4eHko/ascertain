{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["ESNext"],
    "types": ["node"],
    "rootDir": "src",
    "outDir": "build"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/__tests__",
    "**/__bench__",
    "node_modules",
    "**/*.tmp.ts"
  ]
}
